# AI Portfolio Experiment V2 — Environment Variables Copy
# Copy this file to .env and fill in your keys.

# ==========================================
# LLM Provider API Keys
# ==========================================
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

MISTRAL_API_KEY=your_mistral_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
QWEN_API_KEY=your_qwen_api_key_here

# ==========================================
# Data / Tools API Keys (MCP Servers)
# ==========================================
FRED_API_KEY=your_fred_api_key_here         # https://fred.stlouisfed.org/docs/api/api_key.html
FINNHUB_API_KEY=your_finnhub_api_key_here   # https://finnhub.io/
BRAVE_API_KEY=your_brave_api_key_here       # https://brave.com/search/api/

# ==========================================
# Legacy V1 Keys (Manual Execution via Alpaca)
# ==========================================
ALPACA_KEY=your_alpaca_key_here
ALPACA_SECRET=your_alpaca_secret_here
